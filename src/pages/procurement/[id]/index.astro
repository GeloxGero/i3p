---
// src/pages/procurement/[id].astro
import ProcurementLayout from "../../../layouts/ProcurementLayout.astro";
import ProcurementList from '../../../components/ProcurementList';
const { id } = Astro.params;
---

<ProcurementLayout title={`Procurement Details for #${id}`}>
  <main class="p-8">
    <a href="/projects" class="text-primary mb-4 block">← Back to Projects</a>
    <ProcurementList summaryId={id} client:only="react" />
  </main>
</ProcurementLayout>